{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "fict",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src", "vite.config.ts", "server.js"],
  "exclude": ["node_modules", "dist", ".next"]
}
