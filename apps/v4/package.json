{
  "name": "@fictjs/shadcn-v4-site",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
    "start": "NODE_ENV=production node server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fictjs/runtime": "link:../../../packages/runtime",
    "@fictjs/ssr": "link:../../../packages/ssr",
    "express": "^5.1.0",
    "fict": "link:../../../packages/fict"
  },
  "devDependencies": {
    "@fictjs/vite-plugin": "link:../../../packages/vite-plugin",
    "@types/express": "^5.0.5",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
